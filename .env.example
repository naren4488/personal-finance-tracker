# ---------------------------------------------------------------------------
# Setup reference (NOT loaded by Vite — copy values into `.env.development`
# for `npm run dev`, or use `.env.local` / `.env.production` as appropriate).
# ---------------------------------------------------------------------------
#
# Public variables must use the `VITE_` prefix to be exposed to the browser.

# Required — API base URL (no trailing slash required; app strips them).
# Example: https://your-api.example.com/api/v1
VITE_API_BASE_URL=https://expensetracker-api.lazycoderz.com/api/v1

# Optional — when `true`, the Add Account flow does not call POST /accounts
# (UI shows “Unavailable”). No secret value.
# VITE_DISABLE_ACCOUNT_CREATE=true
