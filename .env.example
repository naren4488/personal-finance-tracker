# Public env (exposed to the browser). Must use the VITE_ prefix.
# Leave empty to use same-origin `/api` (see src/lib/env.ts).
VITE_API_BASE_URL=

# Skip POST /accounts (no network call; Add Account sheet shows “Unavailable”).
# VITE_DISABLE_ACCOUNT_CREATE=true

# POST /accounts: default snake_case + numeric amounts (e.g. initial_balance_inr: 0).
# VITE_ACCOUNTS_CAMEL_CASE=true
# VITE_ACCOUNTS_STRING_AMOUNTS=true
